# Google OAuth credentials for YouTube device login
# Create these at https://console.cloud.google.com/apis/credentials
# OAuth application type: TV and Limited Input devices
YOUTUBE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
YOUTUBE_OAUTH_CLIENT_SECRET=your-client-secret
YOUTUBE_INNERTUBE_API_KEY=your-youtube-innertube-api-key

# Optional: use prebuilt images instead of local image names when running docker compose.
# Example:
# VIBETUBE_BACKEND_IMAGE=ghcr.io/owner/repo-backend:v1.0.0
# VIBETUBE_FRONTEND_IMAGE=ghcr.io/owner/repo-frontend:v1.0.0
